{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<style>
    /* Spécifique à la page de connexion */
    .login-page-wrapper {
        height: 100vh;
        overflow: hidden;              /* empêche le scroll */
        background: #e9f7ef;           /* vert clair */
    }
</style>

<div class="login-page-wrapper d-flex justify-content-center align-items-center">
    <div class="card shadow-lg" style="max-width: 400px; width: 100%; border-radius: 1rem;">
        <div class="card-header text-center text-white"
             style="background-color: #198754; border-radius: 1rem 1rem 0 0;">
            <h3 class="mb-0">Connexion</h3>
            <small class="text-light">Accédez à votre espace Ecolito</small>
        </div>

        <div class="card-body p-4 bg-white">
            {% if error %}
                <div class="alert alert-danger py-2">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post">
                <div class="mb-3">
                    <label for="inputEmail" class="form-label">Email</label>
                    <input
                        type="email"
                        value="{{ last_username }}"
                        name="_username"
                        id="inputEmail"
                        class="form-control"
                        required
                        autofocus
                    >
                </div>

                <div class="mb-3">
                    <label for="inputPassword" class="form-label">Mot de passe</label>
                    <input
                        type="password"
                        name="_password"
                        id="inputPassword"
                        class="form-control"
                        required
                    >
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="d-flex justify-content-between align-items-center mb-3">
                
                    <a href="{{ path('app_forgot_password_request') }}" class="text-success small">Mot de passe oublié ?</a>
                </div>

                <button class="btn w-100 text-white" style="background-color: #198754;" type="submit">
                    Se connecter
                </button>
            </form>
        </div>

        <div class="card-footer text-center bg-white" style="border-radius: 0 0 1rem 1rem;">
            <small class="text-muted">
                Nouveau sur Ecolito ?
                <a href="{{ path('app_register') }}" class="text-success fw-semibold">Créer un compte</a>
            </small>
        </div>
    </div>
</div>
{% endblock %}